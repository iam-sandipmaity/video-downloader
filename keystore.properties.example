# Copy this file to `keystore.properties` and fill in real values.
# Keep `keystore.properties` and the referenced keystore files out of version control.

# Stable debug signing for install-over-update behavior on internal debug APKs.
INTERNAL_DEBUG_STORE_FILE=/absolute/path/to/internal-debug.jks
INTERNAL_DEBUG_STORE_PASSWORD=change-me
INTERNAL_DEBUG_KEY_ALIAS=internal-debug
INTERNAL_DEBUG_KEY_PASSWORD=change-me

# Stable release signing for production updates.
RELEASE_STORE_FILE=/absolute/path/to/release.jks
RELEASE_STORE_PASSWORD=change-me
RELEASE_KEY_ALIAS=release
RELEASE_KEY_PASSWORD=change-me
