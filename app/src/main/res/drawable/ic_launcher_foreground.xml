<?xml version="1.0" encoding="utf-8"?>
<!-- Download arrow icon – white on transparent, 108×108dp adaptive icon foreground.
     Safe zone: 66dp circle centred at (54,54). All paths stay well within it. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Arrow stem (top of stem → tip) -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M54,27 L54,60"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="6" />

    <!-- Arrowhead – left prong -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M54,60 L42,48"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="6" />

    <!-- Arrowhead – right prong -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M54,60 L66,48"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="6" />

    <!-- Download tray with rounded corners -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M36,66 L36,72 Q36,78 42,78 L66,78 Q72,78 72,72 L72,66"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="6" />

</vector>
